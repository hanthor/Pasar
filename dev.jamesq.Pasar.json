{
    "app-id": "dev.jamesq.Pasar",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "command": "pasar",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--share=network",
        "--talk-name=org.freedesktop.Flatpak",
        "--filesystem=home",
        "--filesystem=/home/linuxbrew:ro",
        "--env=HOMEBREW_NO_AUTO_UPDATE=1"

    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "blueprint-compiler",
            "buildsystem": "meson",
            "cleanup": ["*"],
            "sources": [
                {
                    "type": "git",
                    "url": "https://gitlab.gnome.org/jwestman/blueprint-compiler.git",
                    "tag": "v0.16.0"
                }
            ]
        },
        {
            "name": "pasar",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "dir",
                    "path": "."
                }
            ]
        }
    ]
}
