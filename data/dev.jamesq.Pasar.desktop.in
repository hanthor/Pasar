[Desktop Entry]
Name=Pasar
Comment=Browse and install Homebrew packages
Exec=pasar %F
Icon=dev.jamesq.Pasar
Terminal=false
Type=Application
Categories=System;PackageManager;
Keywords=homebrew;brew;package;install;software;
StartupNotify=true
DBusActivatable=true
MimeType=text/x-brewfile;application/x-brewfile;
